# ──────────────────────────────────────────────────────────────
# Tamil Panchangam — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────

# ─── Anthropic (required for LLM/AI interpretation features) ───
ANTHROPIC_API_KEY=sk-ant-replace-me

# ─── PostgreSQL (required for the Express/Drizzle layer) ────
DATABASE_URL=postgresql://user:password@localhost:5432/panchangam

# ─── Ports (optional — defaults shown) ──────────────────────
PORT=5001            # Express dev server
# FASTAPI_PORT=8000  # Uvicorn / FastAPI (set via CLI, not read in code)

# ─── Static files path (optional) ───────────────────────────
# Override where FastAPI looks for the built React app.
# Default: <project-root>/dist/public  (auto-detected at runtime)
# STATIC_DIR=/absolute/path/to/dist/public

modules = ["python-3.11", "nodejs-18", "web"]

[env]
PORT = "8000"

[[ports]]
localPort = 8000
externalPort = 80

[workflows]
runButton = "Start App"

[[workflows.workflow]]
name = "Start App"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && cd tamil_panchangam_engine && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[nix]
packages = ["lsof", "mailutils", "sqlite", "duckdb"]
